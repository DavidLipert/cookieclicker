<Window x:Class="cookieclicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cookieclicker"
        mc:Ignorable="d"
        Title="PawClicker (By: Lipert, Šefl)"
        Height="450"
        Width="800"
        Background="White" Icon="/Assetes/Icons/paw_icon_blue.png">

    <Grid>

        <!-- Pozadí -->
        <Border>
            <Border.Background>
                <ImageBrush ImageSource="/Assetes/Backgrounds/mlem.jpg"/>
            </Border.Background>
        </Border>

        <!-- Statistiky -->
        <Border Background="#DCEEFF"
                CornerRadius="12"
                Width="180"
                Height="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="30,30,0,0">

            <StackPanel>
                <Button Content="Reset hry" Height="27"
                             FontSize="16"
                                FontWeight="Bold"
                                     Background="#42A5F5"
                                     Foreground="White"
                                     BorderBrush="#1565C0"
                                     BorderThickness="2"
                                     Cursor="Hand" Click="Button_Click_1"
                                    
                                             />          

                <Label Content="Pawtistiky"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#1565C0"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>

                <TextBlock x:Name="TxtCislo"
                           Text="0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0D47A1"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="TxtCelkemKliknuti"
                           Text="Celkem kliknutí: 0"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Margin="0,10,0,0"
                           Foreground="#1976D2"/>

                <TextBlock x:Name="TxtZaKlik"
                           Text="Počet za kliknutí: 0"
                           FontSize="14"
                           Foreground="#1976D2"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="TxtCelkemItemů"
                           Text="Zakoupeno: 0"
                           FontSize="14"
                           Foreground="#1976D2"
                           HorizontalAlignment="Center"/>
                
                
            </StackPanel>
        </Border>

        <!-- Cookie Button -->
        <Button Content="Paw Pat"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="140"
                Height="140"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                BorderBrush="#1565C0"
                BorderThickness="3"
                Cursor="Hand"
                Click="Button_Click">
            <Button.Background>
                <ImageBrush ImageSource="/Assetes/Backgrounds/paw_pat_bg_blue.png" Stretch="UniformToFill"/>
            </Button.Background>
            
            

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="70"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Obchod -->
        <Button x:Name="shopButon"
                Content="Obchod"
                HorizontalAlignment="Left"
                Margin="58,300,0,0"
                VerticalAlignment="Top"
                Height="45"
                Width="120"
                FontSize="16"
                FontWeight="Bold"
                Background="#42A5F5"
                Foreground="White"
                BorderBrush="#1565C0"
                BorderThickness="2"
                Cursor="Hand"
                Click="shopButon_Click"/>
        
        

        <!-- Automatická produkce -->
        <Border Background="#DCEEFF"
                CornerRadius="10"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40">
        

            <Label x:Name="ZaSekunduLabel"
                   Content="Paws za sekundu: 0"
                   FontSize="16"
                   Foreground="#1565C0"
                   FontWeight="Bold"/>
            
        </Border>

    </Grid>
</Window>