<Window x:Class="cookieclicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cookieclicker"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="800"
        Background="White">

    <Grid>

        <!-- Pozadí -->
        <Border Background="#F4F9FF"/>

        <!-- Statistiky -->
        <Border Background="#DCEEFF"
                CornerRadius="12"
                Width="180"
                Height="120"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="30,30,0,0">

            <StackPanel>
                <Label Content="Pawtistiky"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#1565C0"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,10"/>

                <TextBlock x:Name="TxtCislo"
                           Text="0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#0D47A1"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="TxtZaKlik"
                           Text="Počet za kliknutí: 0"
                           FontSize="14"
                           Foreground="#1976D2"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Cookie Button -->
        <Button Content="Paw Pat"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="140"
                Height="140"
                FontSize="24"
                FontWeight="Bold"
                Background="#2196F3"
                Foreground="White"
                BorderBrush="#1565C0"
                BorderThickness="3"
                Cursor="Hand"
                Click="Button_Click">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="70"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Obchod -->
        <Button x:Name="shopButon"
                Content="Obchod"
                HorizontalAlignment="Left"
                Margin="58,300,0,0"
                VerticalAlignment="Top"
                Height="45"
                Width="120"
                FontSize="16"
                FontWeight="Bold"
                Background="#42A5F5"
                Foreground="White"
                BorderBrush="#1565C0"
                BorderThickness="2"
                Cursor="Hand"
                Click="shopButon_Click"/>

        <!-- Automatická produkce -->
        <Border Background="#DCEEFF"
                CornerRadius="10"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40">

            <Label x:Name="ZaSekunduLabel"
                   Content="Tlapek za sekundu: 0"
                   FontSize="16"
                   Foreground="#1565C0"
                   FontWeight="Bold"/>
        </Border>

    </Grid>
</Window>